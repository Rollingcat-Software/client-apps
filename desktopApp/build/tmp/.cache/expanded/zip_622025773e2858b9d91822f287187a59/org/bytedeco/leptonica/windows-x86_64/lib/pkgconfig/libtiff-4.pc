prefix=D:/a/javacpp-presets/javacpp-presets/leptonica/cppbuild/windows-x86_64
exec_prefix=${prefix}
libdir=D:/a/javacpp-presets/javacpp-presets/leptonica/cppbuild/windows-x86_64/lib
includedir=${prefix}/include

Name: libtiff
Description:  Tag Image File Format (TIFF) library.
Version: 4.6.0
Libs: -L${libdir} -ltiff
Libs.private:  -lm
Cflags: -I${includedir}
Requires.private:  zlib libjpeg libwebp
